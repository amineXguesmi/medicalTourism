{
  "name": "medtour-ai-platform",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/web",
    "apps/backend",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@medtour/web",
    "dev:backend": "npm run start:dev --workspace=@medtour/backend",
    "build:backend": "npm run build --workspace=@medtour/backend",
    "prisma:generate": "npm run prisma:generate --workspace=@medtour/backend",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
